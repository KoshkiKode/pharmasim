{
  "name": "pharmasim-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/desktop-web",
    "build": "npm run build -w apps/desktop-web",
    "desktop": "npm run build -w apps/desktop-web && npm run start -w apps/desktop-app",
    "desktop:make": "npm run build -w apps/desktop-web && npm run make -w apps/desktop-app",
    "mobile": "npm run start -w apps/mobile",
    "bench": "npm run bench -w packages/engine",
    "test:stress": "npm run test:stress -w packages/engine"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
