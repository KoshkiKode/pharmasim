{
  "name": "pharmasim-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run start -w apps/mobile",
    "build": "npm run build -w packages/engine",
    "mobile": "npm run start -w apps/mobile",
    "bench": "npm run bench -w packages/engine",
    "test:stress": "npm run test:stress -w packages/engine",
    "postinstall": "node patch_screens_properly.js"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "@types/react": "~19.2.17"
  },
  "dependencies": {
    "react-native-screens": "^4.25.2"
  },
  "overrides": {
    "@types/react": "~19.2.17"
  }
}
